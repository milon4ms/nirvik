                        <label><input type="checkbox" name="feverHeatChill" value="একদিকে বেশি ঠাণ্ডা"> একদিকে বেশি ঠাণ্ডা</label>
                        <label><input type="checkbox" name="feverHeatChill" value="অচল থাকলে ঠাণ্ডা কমে"> অচল থাকলে ঠাণ্ডা কমে</label>
                        <label><input type="checkbox" name="feverHeatChill" value="বাতাসে থাকলে ঠাণ্ডা বৃদ্ধি"> বাতাসে থাকলে ঠাণ্ডা বৃদ্ধি</label>
                        <label><input type="checkbox" name="feverHeatChill" value="চাদর দিলে আরাম"> চাদর দিলে আরাম</label>
                        <label><input type="checkbox" name="feverHeatChill" value="ধীরে ধীরে কাঁপুনি ওঠা"> ধীরে ধীরে কাঁপুনি ওঠা</label>
                        <label><input type="checkbox" name="feverHeatChill" value="ভেজা কাপড়ে কাঁপুনি বাড়ে"> ভেজা কাপড়ে কাঁপুনি বাড়ে</label>
                        <label><input type="checkbox" name="feverHeatChill" value="নড়াচড়ায় কাঁপুনি বাড়ে"> নড়াচড়ায় কাঁপুনি বাড়ে</label>
                        <label><input type="checkbox" name="feverHeatChill" value="টানা কাঁপুনি"> টানা কাঁপুনি</label>
                        <label><input type="checkbox" name="feverHeatChill" value="দাঁত কটকট করা"> দাঁত কটকট করা</label>
                    </div>
                </div>

                <!-- ৫. ঘাম পর্যায় -->
                <div class="section">
                    <h3 onclick="toggleSection(this)">
                        <span>৫. ঘাম পর্যায়</span>
                        <span class="arrow">▼</span>
                    </h3>
                    <div class="checkbox-group">
                        <label><input type="checkbox" name="feverSweat" value="প্রচুর ঘাম"> প্রচুর ঘাম</label>
                        <label><input type="checkbox" name="feverSweat" value="সামান্য ঘাম"> সামান্য ঘাম</label>
                        <label><input type="checkbox" name="feverSweat" value="মাথায় ঘাম"> মাথায় ঘাম</label>
                        <label><input type="checkbox" name="feverSweat" value="বুকে ঘাম"> বুকে ঘাম</label>
